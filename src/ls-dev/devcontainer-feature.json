{
  "name": "ls-dev",
  "id": "ls-dev",
  "version": "1.2.1",
  "description": "Development environment for lisp-stat with configurable BLAS libraries.",
  "options": {
    "blas": {
      "type": "string",
      "description": "Choose BLAS library",
      "enum": ["intel-mkl", "openblas"],
      "default": "openblas"
    },
    "install_emacs": {
      "type": "boolean",
      "description": "Install Emacs (nox) with SLIME for Common Lisp development",
      "default": true
    }
  },
    "dependsOn": {
        "ghcr.io/symbolics/devcontainer-features/quicklisp:latest": {}
    },
  "postCreateCommand": "sudo /usr/local/share/lisp-stat/link-local-projects.sh"
}